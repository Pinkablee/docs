              {
                "group": "Discord Integration",
                "pages": [
                  "products/free/px-discord/overview",
                  "products/free/px-discord/setup",
                  "products/free/px-discord/configuration",
                  "products/free/px-discord/exports"
                ]
              },
              {
                "group": "Vehicle Spawner",
                "pages": [
                  "products/free/px-spawn/overview",
                  "products/free/px-spawn/setup",
                  "products/free/px-spawn/configuration"
                ]
              },
              {
                "group": "Climate Control",
                "pages": [
                  "products/free/px-climate/overview",
                  "products/free/px-climate/setup",
                  "products/free/px-climate/configuration",
                  "products/free/px-climate/exports"
                ]
              }
            ]
          },
          {
            "group": "Paid Releases",
            "pages": [
              {
                "group": "Admin Menu",
                "pages": [
                  "products/paid/px-admin/overview",
                  "products/paid/px-admin/setup",
